{
  "manifest_version": 3,
  "name": "AI Chatbot Browser Extension",
  "version": "1.0.0",
  "description": "A cross-browser AI chatbot that injects a floating chat UI into any webpage.",
  "permissions": ["activeTab", "storage", "scripting", "webNavigation", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
